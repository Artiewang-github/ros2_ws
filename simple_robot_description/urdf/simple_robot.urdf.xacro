<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="simple_robot">

    <link name="base_link"/>

    <link name="moving_link">
        <visual>
            <geometry>
                <box size="0.1 0.1 0.5"/>
            </geometry>
            <origin xyz="0 0 0.25"/>
        </visual>
    </link>

    <joint name="joint_1" type="revolute">
        <parent link="base_link"/>
        <child link="moving_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/> <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0"/>
    </joint>

    <ros2_control name="MockHardware" type="system">
        <hardware>
            <plugin>mock_components/GenericSystem</plugin>
            <param name="calculate_dynamics">true</param>
        </hardware>
        
        <joint name="joint_1">
            <command_interface name="position">
                <param name="min">-3.14</param>
                <param name="max">3.14</param>
            </command_interface>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

</robot>
